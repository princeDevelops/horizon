{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*", "src/utils"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/__tests__/**",
    "test/**"
  ],
  "references": [{ "path": "../../shared" }]
}
