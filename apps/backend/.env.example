NODE_ENV=development
PORT=5000
LOG_LEVEL=info

MONGO_URI=mongodb://localhost:27017/horizon

ACCESS_TOKEN_SECRET=replace-with-strong-access-secret
REFRESH_TOKEN_SECRET=replace-with-strong-refresh-secret

# Comma-separated allowlist for browser origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5000

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/oauth/github/callback
